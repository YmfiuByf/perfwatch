# PerfWatch runtime configuration (sample).
# No secrets are required for this project; values here are safe to modify.

DB_PATH=./data/perfwatch.db
INTERVAL_SEC=5

WEB_ENABLED=1
WEB_HOST=0.0.0.0
WEB_PORT=8080

PING_HOST=8.8.8.8
PING_TIMEOUT_SEC=2

HTTP_URL=https://www.google.com/generate_204
HTTP_TIMEOUT_SEC=5

PING_LATENCY_WARN_MS=50
PING_LATENCY_CRIT_MS=100

HTTP_LATENCY_WARN_MS=50
HTTP_LATENCY_CRIT_MS=100

RULES_PATH=./rules.yaml
RULES_RELOAD_SEC=5

# --- Alert dedup / cooldown ---
ALERT_COOLDOWN_SEC=300
ALERT_DEDUP_MODE=key_severity_title   # or: key_only

# --- Webhook ---
WEBHOOK_ENABLED=true
WEBHOOK_URL=http://host.docker.internal:19099/webhook
WEBHOOK_TOKEN=test123
WEBHOOK_TOKEN_PREFIX=Bearer
WEBHOOK_TIMEOUT_SEC=5
WEBHOOK_MIN_SEVERITY=warn            # warn or critical

# --- AI analysis (DeepSeek) ---
AI_ENABLED=1
DEEPSEEK_API_KEY=sk-5bacab9504154817a0f9dfe263a305bb
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_TIMEOUT_SEC=20
AI_MAX_TOKENS=300

# 为了省钱/降噪：同一个 probe 的 AI 分析冷却时间（秒）
AI_COOLDOWN_SEC=120
# 只对 critical 做 AI（可选：critical,warn）
AI_ON_SEVERITY=critical

