# PerfWatch configuration example.
# Configuration values are centralized here; create a .env file based on this template and adjust as needed.

# SQLite database path (relative to project root recommended)
DB_PATH=./data/perfwatch.db

# Scheduler interval in seconds
INTERVAL_SEC=30

# Enable built-in web API server (0/1)
WEB_ENABLED=1
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Demo collectors configuration
PING_HOST=8.8.8.8
PING_TIMEOUT_SEC=2

HTTP_URL=https://example.com
HTTP_TIMEOUT_SEC=5

# Threshold rules (ms)
PING_LATENCY_WARN_MS=250
PING_LATENCY_CRIT_MS=600

HTTP_LATENCY_WARN_MS=800
HTTP_LATENCY_CRIT_MS=1500

RULES_PATH=./rules.yaml
RULES_RELOAD_SEC=5

# --- Alert dedup / cooldown ---
ALERT_COOLDOWN_SEC=300
ALERT_DEDUP_MODE=key_severity_title   # or: key_only

# --- Webhook ---
WEBHOOK_ENABLED=0
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SEC=5
WEBHOOK_MIN_SEVERITY=warn            # warn or critical
